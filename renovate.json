{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "timezone": "Europe/Paris",
  "schedule": ["before 5am on monday"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "minimumReleaseAge": "3 days",
  "rangeStrategy": "bump",
  "separateMajorMinor": false,
  "separateMinorPatch": false,
  "separateMultipleMajor": false,
  "rebaseWhen": "behind-base-branch",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": false
  },
  "packageRules": [
    {
      "description": "Default group: everything not matched by a more specific rule below (e.g. Rust/cargo).",
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest", "pinDigest", "bump", "rollback", "replacement"],
      "groupName": "angos-core",
      "groupSlug": "angos-core",
      "commitMessageTopic": "angos-core dependencies",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "description": "UI (SvelteKit): group every dependency under ui/ into one PR.",
      "matchFileNames": ["ui/**"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest", "pinDigest", "bump", "rollback", "replacement"],
      "groupName": "angos-ui",
      "groupSlug": "angos-ui",
      "commitMessageTopic": "angos-ui dependencies",
      "semanticCommitType": "chore",
      "semanticCommitScope": "ui",
      "postUpdateOptions": ["npmDedupe"]
    },
    {
      "description": "Website (Docusaurus): group every dependency under website/ into one PR.",
      "matchFileNames": ["website/**"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest", "pinDigest", "bump", "rollback", "replacement"],
      "groupName": "website",
      "groupSlug": "website",
      "commitMessageTopic": "website dependencies",
      "semanticCommitType": "chore",
      "semanticCommitScope": "website",
      "postUpdateOptions": ["npmDedupe"]
    },
    {
      "description": "GitHub Actions: keep workflow action versions current in a single PR (versions + digests + pins together).",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest", "pinDigest", "bump", "rollback", "replacement"],
      "groupName": "github actions",
      "groupSlug": "github-actions",
      "commitMessageTopic": "github actions",
      "semanticCommitType": "chore",
      "semanticCommitScope": "ci"
    },
    {
      "description": "Lockfile maintenance for angos-ui (ui/package-lock.json) — one PR.",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "matchFileNames": ["ui/**"],
      "groupName": "angos-ui lockfile",
      "groupSlug": "angos-ui-lockfile",
      "commitMessageTopic": "ui/package-lock.json",
      "semanticCommitType": "chore",
      "semanticCommitScope": "ui"
    },
    {
      "description": "Lockfile maintenance for website (website/package-lock.json) — one PR.",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "matchFileNames": ["website/**"],
      "groupName": "website lockfile",
      "groupSlug": "website-lockfile",
      "commitMessageTopic": "website/package-lock.json",
      "semanticCommitType": "chore",
      "semanticCommitScope": "website"
    },
    {
      "description": "Lockfile maintenance for angos-core (Cargo.lock) — one PR.",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "matchManagers": ["cargo"],
      "groupName": "angos-core lockfile",
      "groupSlug": "angos-core-lockfile",
      "commitMessageTopic": "Cargo.lock",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "description": "Hold back major bumps for 7 days to let ecosystems stabilize.",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "7 days"
    }
  ]
}
