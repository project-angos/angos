{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Exactly one weekly PR per subsystem (angos-core, angos-ui, website), each covering version updates, security fixes and lockfile maintenance. Dedicated vulnerability-alert PRs are disabled on purpose: Renovate cannot group them into existing PRs (they force their own branch per dependency), so security fixes ride the subsystem PRs instead.",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "timezone": "Europe/Paris",
  "schedule": ["before 5am on monday"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "bump",
  "separateMajorMinor": false,
  "separateMinorPatch": false,
  "separateMultipleMajor": false,
  "rebaseWhen": "behind-base-branch",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": false
  },
  "packageRules": [
    {
      "description": "Core: everything not claimed by a rule below — cargo, Dockerfile, GitHub Actions, etc.",
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest", "pinDigest", "bump", "rollback", "replacement"],
      "groupName": "angos-core",
      "groupSlug": "angos-core",
      "commitMessageTopic": "angos-core dependencies",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "description": "UI (SvelteKit): group every dependency under ui/ into one PR.",
      "matchFileNames": ["ui/**"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest", "pinDigest", "bump", "rollback", "replacement"],
      "groupName": "angos-ui",
      "groupSlug": "angos-ui",
      "commitMessageTopic": "angos-ui dependencies",
      "semanticCommitType": "chore",
      "semanticCommitScope": "ui",
      "postUpdateOptions": ["npmDedupe"]
    },
    {
      "description": "Website (Docusaurus): group every dependency under website/ into one PR.",
      "matchFileNames": ["website/**"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest", "pinDigest", "bump", "rollback", "replacement"],
      "groupName": "website",
      "groupSlug": "website",
      "commitMessageTopic": "website dependencies",
      "semanticCommitType": "chore",
      "semanticCommitScope": "website",
      "postUpdateOptions": ["npmDedupe"]
    },
    {
      "description": "Fold lockfile maintenance for anything outside ui/ and website/ (Cargo.lock today) into the angos-core PR. group.branchTopic must be forced because Renovate hard-prefixes lockFileMaintenance group slugs with 'lock-file-maintenance-', which would otherwise put it on a separate branch/PR.",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "groupName": "angos-core",
      "groupSlug": "angos-core",
      "group": { "branchTopic": "angos-core" },
      "commitMessageAction": "Update",
      "commitMessageTopic": "angos-core dependencies",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "description": "Fold ui/package-lock.json maintenance into the angos-ui PR (same forced branchTopic trick as above).",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "matchFileNames": ["ui/**"],
      "groupName": "angos-ui",
      "groupSlug": "angos-ui",
      "group": { "branchTopic": "angos-ui" },
      "commitMessageAction": "Update",
      "commitMessageTopic": "angos-ui dependencies",
      "semanticCommitType": "chore",
      "semanticCommitScope": "ui"
    },
    {
      "description": "Fold website/package-lock.json maintenance into the website PR (same forced branchTopic trick as above).",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "matchFileNames": ["website/**"],
      "groupName": "website",
      "groupSlug": "website",
      "group": { "branchTopic": "website" },
      "commitMessageAction": "Update",
      "commitMessageTopic": "website dependencies",
      "semanticCommitType": "chore",
      "semanticCommitScope": "website"
    }
  ]
}
