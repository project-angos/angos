{
  "name": "angos-docs",
  "version": "1.0.0-snapshot",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "copy-images": "mkdir -p static/docs/images && cp ../doc/images/*.png ../doc/images/*.svg static/docs/images/",
    "start": "npm run copy-images && docusaurus start",
    "build": "npm run copy-images && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.2",
    "@docusaurus/preset-classic": "^3.10.2",
    "@docusaurus/theme-mermaid": "^3.10.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@mdx-js/react": "^3.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.2",
    "@docusaurus/types": "^3.10.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.7",
    "shell-quote": "^1.10.0",
    "ws": "^8.21.1",
    "qs": "^6.15.3",
    "uuid": "^14.0.1",
    "dompurify": "^3.4.12",
    "http-proxy-middleware": "^4.2.0",
    "joi": "^18.2.3",
    "launch-editor": "^2.14.1",
    "@babel/core": "^8.0.1",
    "webpack-dev-server": "^6.0.0",
    "gray-matter": {
      "js-yaml": "^5.2.1"
    }
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=24.18.0"
  }
}
