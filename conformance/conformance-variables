export OCI_ROOT_URL="http://127.0.0.1:8000"
export OCI_NAMESPACE="conformance/test"
export OCI_CROSSMOUNT_NAMESPACE="conformance/cross-mount-test"

# Which workflows to run
export OCI_TEST_PULL=1
export OCI_TEST_PUSH=1
export OCI_TEST_CONTENT_DISCOVERY=1
export OCI_TEST_CONTENT_MANAGEMENT=1
export OCI_AUTOMATIC_CROSSMOUNT=1

# Extra settings
export OCI_HIDE_SKIPPED_WORKFLOWS=0
export OCI_DEBUG=0
export OCI_DELETE_MANIFEST_BEFORE_BLOBS=0 # defaults to OCI_DELETE_MANIFEST_BEFORE_BLOBS=1 if not set

# angos is sha256-only by design; sha512 is optional per the OCI image-spec.
export OCI_DATA_SHA512=0
